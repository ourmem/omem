# =============================================================================
# omem-server configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Server
OMEM_PORT=8080
OMEM_LOG_LEVEL=info

# Storage (S3)
OMEM_S3_BUCKET=omem-data

# For local dev with MinIO (set automatically in docker-compose.yml):
# AWS_ENDPOINT_URL=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1

# For production AWS S3:
# AWS_REGION=us-east-1
# (uses IAM role / instance profile — no keys needed)

# Embedding provider: noop | bedrock | openai-compatible
OMEM_EMBED_PROVIDER=noop

# Bedrock embedding (requires AWS credentials):
# OMEM_EMBED_PROVIDER=bedrock

# OpenAI-compatible embedding:
# OMEM_EMBED_PROVIDER=openai-compatible
# OMEM_EMBED_API_KEY=sk-xxx
# OMEM_EMBED_BASE_URL=https://api.openai.com
# OMEM_EMBED_MODEL=text-embedding-3-small

# LLM provider for smart extraction: (empty) | openai-compatible | bedrock
# OMEM_LLM_PROVIDER=openai-compatible
# OMEM_LLM_API_KEY=sk-xxx
# OMEM_LLM_BASE_URL=https://api.openai.com
# OMEM_LLM_MODEL=gpt-4o-mini
